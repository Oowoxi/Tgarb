javascript:(function(){
    if(window.isAutoBotRunning) return;
    window.isAutoBotRunning = true;

    document.body.innerHTML = '';
    document.body.style.margin = '0';
    document.body.style.overflow = 'hidden';

    let iframe = document.createElement('iframe');
    iframe.src = location.href;
    iframe.style.width = '100vw';
    iframe.style.height = '100vh';
    iframe.style.border = 'none';
    document.body.appendChild(iframe);

    let step = 0;
    let lastTime = Date.now();

    function runBot() {
        try {
            let doc = iframe.contentWindow.document;
            let now = Date.now();

            // 1. الانتظار 5 ثوانٍ لضمان ظهور الصفحة، ثم الضغط على زر العين (التخفي)
            if (step === 0 && (now - lastTime > 5000)) {
                // البحث عن زر العين باستخدام الكلاس أو الأيدي
                let eyeBtn = doc.querySelector('.fa-eye') || doc.querySelector('#stealth-btn'); 
                if (eyeBtn && eyeBtn.offsetParent !== null) {
                    eyeBtn.click();
                }
                // ننتقل للخطوة التالية سواء وجد الزر أم لا لكي لا يتوقف البوت
                step = 1;
                lastTime = now;
            } 
            // 2. الانتظار نصف ثانية (500 ملي ثانية) ثم الضغط على زر الدخول
            else if (step === 1 && (now - lastTime > 500)) {
                let loginBtn = Array.from(doc.querySelectorAll('.th-login-btn')).find(el => el.offsetParent !== null);
                if (loginBtn) {
                    loginBtn.click();
                    step = 2;
                    lastTime = now;
                }
            }
            // 3. الانتظار 4 ثوانٍ بعد ضغط الدخول لضمان اكتمال تحميل الموقع
            else if (step === 2 && (now - lastTime > 4000)) {
                let usersBtn = doc.querySelector('.th-d0-users');
                if (usersBtn) {
                    usersBtn.click();
                    step = 3;
                    lastTime = now;
                }
            }
            // --- من هنا تبدأ السرعة القصوى ---
            // 4. كتابة البحث (انتظار أجزاء بسيطة من الثانية)
            else if (step === 3 && (now - lastTime > 300)) {
                let searchInput = doc.getElementById('usearch');
                if (searchInput) {
                    searchInput.value = "87";
                    searchInput.dispatchEvent(new Event('input', { bubbles: true }));
                    searchInput.dispatchEvent(new KeyboardEvent('keyup', { bubbles: true }));
                    step = 4;
                    lastTime = now;
                }
            }
            // 5. النقر على المستخدم 
            else if (step === 4 && (now - lastTime > 500)) {
                let visibleUsers = Array.from(doc.querySelectorAll('#users .uzr.uhtml')).filter(el => el.offsetParent !== null);
                if (visibleUsers.length > 0) {
                    visibleUsers[0].click();
                    step = 5;
                    lastTime = now;
                }
            }
            // 6. النقر على النجمة 
            else if (step === 5 && (now - lastTime > 400)) {
                let starBtn = doc.querySelector('#upro .stars-users .star5');
                if (starBtn) {
                    starBtn.click();
                }
                step = 6;
                lastTime = now;
            }
            // 7. إغلاق البروفايل 
            else if (step === 6 && (now - lastTime > 300)) {
                let closeBtn = doc.querySelector('#upro .fa-times');
                if (closeBtn) closeBtn.click();
                step = 7;
                lastTime = now;
            }
            // 8. فتح الإعدادات 
            else if (step === 7 && (now - lastTime > 300)) {
                let settingsBtn = doc.querySelector('.th-d0-settings');
                if (settingsBtn) {
                     settingsBtn.click();
                }
                step = 8;
                lastTime = now;
            }
            // 9. تسجيل الخروج 
            else if (step === 8 && (now - lastTime > 300)) {
                let logoutBtn = doc.querySelector('label.SERT');
                if (logoutBtn) {
                    logoutBtn.click();
                }
                step = 9;
                lastTime = now;
            }
            // 10. إعادة الدورة بعد ثانية واحدة من الخروج ليكون الموقع جاهزاً مجدداً
            else if (step === 9 && (now - lastTime > 1000)) {
                step = 0;
                lastTime = now;
            }
        } catch(e) {
        }
    }

    // سرعة الفحص عالية جداً (كل 100 ملي ثانية) لضمان تنفيذ الخطوات السريعة فوراً
    setInterval(runBot, 100);
    alert('تم تشغيل الإطار الوهمي مع ميزة التخفي!');
})();
