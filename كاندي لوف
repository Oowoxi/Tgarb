javascript:(function(){
    if(window.isAutoBotRunning) return;
    window.isAutoBotRunning = true;

    document.body.innerHTML = '';
    document.body.style.margin = '0';
    document.body.style.overflow = 'hidden';

    let iframe = document.createElement('iframe');
    iframe.src = location.href;
    iframe.style.width = '100vw';
    iframe.style.height = '100vh';
    iframe.style.border = 'none';
    document.body.appendChild(iframe);

    let step = 0;
    let lastTime = Date.now();

    function runBot() {
        try {
            let doc = iframe.contentWindow.document;
            let now = Date.now();

            // تسجيل الدخول (انتظار نصف ثانية)
            if (step === 0 && (now - lastTime > 500)) {
                let loginBtn = Array.from(doc.querySelectorAll('.th-login-btn')).find(el => el.offsetParent !== null);
                if (loginBtn) {
                    loginBtn.click();
                    step = 1;
                    lastTime = now;
                }
            } 
            // فتح قائمة المستخدمين (انتظار نصف ثانية)
            else if (step === 1 && (now - lastTime > 500)) {
                let usersBtn = doc.querySelector('.th-d0-users');
                if (usersBtn) {
                    usersBtn.click();
                    step = 2;
                    lastTime = now;
                }
            }
            // كتابة رقم 87 في البحث (انتظار 0.3 ثانية)
            else if (step === 2 && (now - lastTime > 300)) {
                let searchInput = doc.getElementById('usearch');
                if (searchInput) {
                    searchInput.value = "87";
                    searchInput.dispatchEvent(new Event('input', { bubbles: true }));
                    searchInput.dispatchEvent(new KeyboardEvent('keyup', { bubbles: true }));
                    step = 3;
                    lastTime = now;
                }
            }
            // النقر على المستخدم بعد البحث (انتظار نصف ثانية لظهور النتائج)
            else if (step === 3 && (now - lastTime > 500)) {
                let visibleUsers = Array.from(doc.querySelectorAll('#users .uzr.uhtml')).filter(el => el.offsetParent !== null);
                if (visibleUsers.length > 0) {
                    visibleUsers[0].click();
                    step = 4;
                    lastTime = now;
                }
            }
            // النقر على النجمة (انتظار 0.4 ثانية لظهور البروفايل)
            else if (step === 4 && (now - lastTime > 400)) {
                let starBtn = doc.querySelector('#upro .stars-users .star5');
                if (starBtn) {
                    starBtn.click();
                }
                step = 5;
                lastTime = now;
            }
            // إغلاق البروفايل (انتظار 0.3 ثانية)
            else if (step === 5 && (now - lastTime > 300)) {
                let closeBtn = doc.querySelector('#upro .fa-times');
                if (closeBtn) closeBtn.click();
                step = 6;
                lastTime = now;
            }
            // فتح الإعدادات (انتظار 0.3 ثانية)
            else if (step === 6 && (now - lastTime > 300)) {
                let settingsBtn = doc.querySelector('.th-d0-settings');
                if (settingsBtn) {
                     settingsBtn.click();
                }
                step = 7;
                lastTime = now;
            }
            // تسجيل الخروج (انتظار 0.3 ثانية)
            else if (step === 7 && (now - lastTime > 300)) {
                let logoutBtn = doc.querySelector('label.SERT');
                if (logoutBtn) {
                    logoutBtn.click();
                }
                step = 8;
                lastTime = now;
            }
            // إعادة الدورة (انتظار 0.5 ثانية بعد الخروج)
            else if (step === 8 && (now - lastTime > 500)) {
                step = 0;
                lastTime = now;
            }
        } catch(e) {
        }
    }

    // تم التعديل هنا ليعمل بسرعة فائقة (كل 100 ملي ثانية بدلاً من 1000)
    setInterval(runBot, 100);
    alert('تم تشغيل الإطار الوهمي السريع!');
})();
